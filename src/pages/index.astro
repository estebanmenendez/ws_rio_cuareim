---
import Layout from '~/layouts/PageLayout.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Features2 from '~/components/widgets/Features2.astro';
import { Icon } from 'astro-icon/components';

// Importación de las imágenes oficiales del repositorio
import img1 from '~/assets/images/img1.png';
import img2 from '~/assets/images/img2.png';

const metadata = {
  title: 'Widows Sons — Chapter Río Cuareim',
  ignoreTitleTemplate: true,
};

// Configuración del pie de página para este repositorio
const footerData = {
  secondaryLinks: [
    { text: 'Diseñado por Steb · Widows Sons Río Cuareim © 2026', href: '#' },
  ],
};
---

<Layout metadata={metadata} footerData={footerData}>

  <!-- 1. HERO CON PANTALLA COMPLETA Y ENFOQUE FRONTERIZO -->
  <section class="relative h-screen flex items-center justify-center bg-black overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={img1.src} alt="Fondo Oficial Río Cuareim" class="w-full h-full object-cover opacity-60" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-transparent to-black"></div>
    </div>
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
      <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 uppercase" style="text-shadow: 3px 3px 6px rgba(0,0,0,0.9);">
        WIDOWS SONS <br /> <span class="text-[#d4af37]">CHAPTER RÍO CUAREIM</span>
      </h1>
      <p class="text-xl md:text-2xl text-zinc-200 mb-10 font-medium">
        Asociación Internacional de Masones Motociclistas · Artigas, Uruguay.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#contacto" class="bg-[#d4af37] text-black font-bold py-4 px-10 rounded-full no-underline uppercase tracking-widest hover:bg-white transition-colors">Unirse a la Ruta</a>
        <a href="#eventos" class="text-white font-semibold py-4 px-10 no-underline hover:text-[#d4af37]">Próximos Eventos ↓</a>
      </div>
    </div>
  </section>

  <!-- 2. TRADICIÓN, CAMINO E INTEGRACIÓN (REEMPLAZA A RÍO URUGUAY) -->
  <Content
    id="quienes-somos"
    isReversed
    tagline="Nuestra Historia"
    title="Integración y Camino"
    items={[
      {
        title: 'Presencia Institucional',
        description: 'Consolidamos la presencia de los Widows Sons en el norte uruguayo, bajo la legítima Carta Patente otorgada por el Gran Chapter Uruguay.',
        icon: 'tabler:building-community',
      },
      {
        title: 'Atención Directa',
        description: 'Si eres un Hermano buscando contacto en el norte de la república o tienes una consulta institucional, puedes escribirnos directamente.',
        icon: 'tabler:message-circle',
        callToAction: {
          text: 'Enviar Mensaje',
          href: '#contacto',
          variant: 'link',
        },
      },
      {
        title: 'Membresía y Consulta',
        description: 'Información sobre requisitos de ingreso para Masones y actividades de nuestro Chapter en la región.',
        icon: 'tabler:shield-check',
        callToAction: {
          text: 'Consultar Membresía',
          href: '#contacto',
          variant: 'link',
        },
      },
    ]}
    image={{
      src: img2,
      alt: 'Detalle institucional Widows Sons Río Cuareim',
    }}
  >
    <Fragment slot="content">
      <div class="text-muted dark:text-slate-400">
        <p class="mb-4">
          La expansión de los <strong>Widows Sons</strong> hacia el norte del país representó un paso clave para la descentralización y la integración de la orden en las rutas nacionales. Lo que nació compartiendo una pasión compartida, encontró en el departamento de Artigas un pilar sólido fundado en la regularidad.
        </p>
        <p class="mb-4">
          Nuestra identidad está profundamente ligada al entorno del Río Cuareim, un símbolo que lejos de dividir, representa un lazo de unión, intercambio y presencia solidaria para todas las comunidades de la frontera.
        </p>
        <p>
          Hoy, portar este parche en el norte significa defender el civismo, el auxilio mutuo y el respeto por las leyes cívicas, reafirmando que el verdadero camino del Mason se construye en cada kilómetro recorrido con honor y discreción.
        </p>
      </div>
      
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mt-8 mb-2">
        Mística del Norte
      </h3>
      <p class="text-lg text-[#d4af37] font-semibold italic">
        Una hermandad que une caminos, donde el asfalto y la virtud no conocen fronteras.
      </p>
    </Fragment>
  </Content>

  <!-- 3. PILARES DEL CAPÍTULO -->
  <Features
    id="pilares"
    tagline="Valores"
    title="Pilares del Chapter"
    items={[
      { title: 'Fraternidad', description: 'Lazos indisolubles entre Hermanos del norte.', icon: 'tabler:users' },
      { title: 'Integración', description: 'El Río Cuareim como puente de unión cultural.', icon: 'tabler:world-latitude' },
      { title: 'Caridad', description: 'Asistencia a la viuda, el huérfano y los necesitados.', icon: 'tabler:heart' },
      { title: 'Regularidad', description: 'Bajo el aval del Gran Chapter de Uruguay.', icon: 'tabler:certificate' },
      { title: 'Unidad', description: 'Cohesión con nuestros Chapters hermanos.', icon: 'tabler:shield-check' },
      { title: 'Pasión', description: 'Motociclismo seguro y compañerismo en la ruta.', icon: 'tabler:motorbike' },
    ]}
  />

  <!-- 4. CRÓNICAS Y RODADAS (FEED DE EVENTOS) -->
  <BlogLatestPosts
    id="eventos"
    title="Próximos Eventos y Rodadas del Norte"
    subtitle="Participa en nuestras actividades y salidas oficiales en el departamento de Artigas."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-black"></div>
    </Fragment>
  </BlogLatestPosts>

  <!-- 5. SECCIÓN DE CONTACTO DEL NORTE -->
  <section id="contacto" class="relative py-16 bg-black border-t border-[#d4af37]/10">
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-white uppercase tracking-widest mb-4">¡Escríbenos!</h2>
        <p class="text-zinc-400 text-lg mb-8">
          Si tienes consultas sobre el Chapter o nuestras actividades benéficas en la región norte, completa el formulario y nos pondremos en contacto contigo a la brevedad.
        </p>
        
        <div class="space-y-6">
          <div class="flex items-start">
            <Icon name="tabler:map-pin" class="w-6 h-6 text-[#d4af37] mr-4" />
            <div>
              <h4 class="text-white font-bold">Presencia en la Frontera</h4>
              <p class="text-zinc-400">Artigas, Bella Unión y rutas de influencia del Río Cuareim — Uruguay</p>
            </div>
          </div>
          <div class="flex items-start">
            <Icon name="tabler:message-circle" class="w-6 h-6 text-[#d4af37] mr-4" />
            <div>
              <h4 class="text-white font-bold">Atención Directa</h4>
              <p class="text-zinc-400">Canal oficial de comunicación vía web para el norte del país.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-zinc-900/50 p-8 rounded-lg border border-[#d4af37]/20">
        <form action="https://formspree.io/f/xpqkgznj" method="POST" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-zinc-300 mb-1">Nombre completo</label>
            <input type="text" name="name" id="name" required class="w-full bg-black border border-zinc-700 text-white rounded px-4 py-3 focus:border-[#d4af37] outline-none transition-colors" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-zinc-300 mb-1">Correo electrónico</label>
            <input type="email" name="email" id="email" required class="w-full bg-black border border-zinc-700 text-white rounded px-4 py-3 focus:border-[#d4af37] outline-none transition-colors" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-zinc-300 mb-1">Tu mensaje</label>
            <textarea id="message" name="message" rows="4" required class="w-full bg-black border border-zinc-700 text-white rounded px-4 py-3 focus:border-[#d4af37] outline-none transition-colors"></textarea>
          </div>
          <button type="submit" class="w-full bg-[#d4af37] text-black font-bold py-3 rounded uppercase tracking-widest hover:bg-white transition-all">
            Enviar mensaje
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- 6. CIERRE Y LEMA DEL CAPÍTULO -->
  <section class="py-16 bg-black border-t border-[#d4af37]/20">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 uppercase tracking-widest">
        Widows Sons <span class="text-[#d4af37]">Río Cuareim</span>
      </h2>
      <p class="text-xl text-zinc-400 max-w-2xl mx-auto italic font-light">
        "No rodamos para escapar de la vida, sino para que la vida no se nos escape."
      </p>
      <div class="mt-8 w-24 h-px bg-[#d4af37] mx-auto opacity-50"></div>
    </div>
  </section>

</Layout>
