---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

// IMPORTACIONES DE IMÁGENES (Verificadas)
import imgRemera from '~/assets/images/remera-ws.png';
import imgParche from '~/assets/images/parche-litoral.png';
import imgRitohouse from '~/assets/images/pieza-yeso.png';
import imgGuantes from '~/assets/images/guantes-cuero.png';
import imgGorros from '~/assets/images/gorros-capitulo.png';
import imgVelas from '~/assets/images/velas-simbolicas.png';

const metadata = {
  title: 'Colabora — Widows Sons Río Uruguay',
};
---

<Layout metadata={metadata}>
  <!-- 1. INTRODUCCIÓN  -->
  <Features2
    title="Formas de Apoyar nuestra Causa"
    subtitle="Tu contribución se transforma en acciones concretas en el litoral uruguayo. Elige cómo quieres sumarte a nuestra marcha filantrópica."
    items={[
      {
        title: 'Tienda de Merchandising',
        description: 'Adquiere productos oficiales. El 100% de las ganancias se destina al fondo de ayuda social.',
        icon: 'tabler:shopping-bag',
        callToAction: { text: 'Ver Catálogo', href: '#tienda', variant: 'link' },
      },
      {
        title: 'Sponsors y Empresas',
        description: 'Programa para socios comerciales que deseen vincular su marca con nuestros valores de servicio.',
        icon: 'tabler:building-store',
        callToAction: { text: 'Saber más', href: '#sponsors', variant: 'link' },
      },
      {
        title: 'Donación Civil',
        description: 'Aportes directos o materiales en desuso para nuestras intervenciones en la comunidad.',
        icon: 'tabler:heart-handshake',
        callToAction: { text: '¿Cómo donar?', href: '#donaciones', variant: 'link' },
      },
    ]}
  />

  <!-- 2. SECCIÓN DE TIENDA OFICIAL (6 PRODUCTOS) -->
  <section id="tienda" class="px-4 py-16 mx-auto max-w-7xl lg:py-20">
    <div class="max-w-xl mb-10 md:mx-auto sm:text-center lg:max-w-2xl md:mb-12">
      <h2 class="text-[#d4af37] font-bold tracking-tight text-3xl sm:text-4xl uppercase mb-4">Tienda Oficial</h2>
      <p class="text-zinc-400 italic">Cada compra es un aporte directo a nuestras misiones en el litoral. Fraternidad en cada pieza.</p>
    </div>

    <div class="grid gap-6 row-gap-5 md:grid-cols-3">
      <!-- Fila 1 -->
      <div class="flex flex-col p-4 border border-[#d4af37]/20 rounded-lg bg-zinc-900/50 hover:border-[#d4af37] transition-all">
        <div class="aspect-square bg-zinc-800 rounded mb-4 overflow-hidden flex items-center justify-center">
          <Image src={imgRemera} alt="Remera Oficial WS Río Uruguay" class="object-cover w-full h-full" />
        </div>
        <h3 class="font-bold text-white uppercase tracking-wider text-sm">Remera Oficial WS Río Uruguay</h3>
        <p class="text-xs text-zinc-400 mt-2 mb-4">Algodón premium con logo bordado en espalda y frente.</p>
        <div class="mt-auto flex justify-between items-center">
          <span class="text-[#d4af37] font-bold">$1.200</span>
          <a href="/#contacto" class="text-[10px] bg-[#d4af37] text-black px-3 py-1 rounded font-bold uppercase hover:bg-white transition-colors">Consultar</a>
        </div>
      </div>

      <div class="flex flex-col p-4 border border-[#d4af37]/20 rounded-lg bg-zinc-900/50 hover:border-[#d4af37] transition-all">
        <div class="aspect-square bg-zinc-800 rounded mb-4 overflow-hidden flex items-center justify-center">
          <Image src={imgParche} alt="Parche Litoral Oeste" class="object-cover w-full h-full" />
        </div>
        <h3 class="font-bold text-white uppercase tracking-wider text-sm">Parche "Litoral Oeste"</h3>
        <p class="text-xs text-zinc-400 mt-2 mb-4">Parche bordado de alta resistencia para chalecos o camperas.</p>
        <div class="mt-auto flex justify-between items-center">
          <span class="text-[#d4af37] font-bold">$850</span>
          <a href="/#contacto" class="text-[10px] bg-[#d4af37] text-black px-3 py-1 rounded font-bold uppercase hover:bg-white transition-colors">Consultar</a>
        </div>
      </div>

      <div class="flex flex-col p-4 border border-[#d4af37]/20 rounded-lg bg-zinc-900/50 hover:border-[#d4af37] transition-all">
        <div class="aspect-square bg-zinc-800 rounded mb-4 overflow-hidden flex items-center justify-center">
          <Image src={imgRitohouse} alt="Escuadra y Compás WS Edición Yeso" class="object-cover w-full h-full" />
        </div>
        <h3 class="font-bold text-white uppercase tracking-wider text-sm">Escuadra y Compás WS (Edición Yeso)</h3>
        <p class="text-xs text-zinc-400 mt-2 mb-4">Pieza decorativa artesanal producida por Ritohouse.</p>
        <div class="mt-auto flex justify-between items-center">
          <span class="text-[#d4af37] font-bold">$1.200</span>
          <a href="/#contacto" class="text-[10px] bg-[#d4af37] text-black px-3 py-1 rounded font-bold uppercase hover:bg-white transition-colors">Consultar</a>
        </div>
      </div>

      <!-- Fila 2 -->
      <div class="flex flex-col p-4 border border-[#d4af37]/20 rounded-lg bg-zinc-900/50 hover:border-[#d4af37] transition-all">
        <div class="aspect-square bg-zinc-800 rounded mb-4 overflow-hidden flex items-center justify-center">
          <Image src={imgGuantes} alt="Guantes de cuero personalizados" class="object-cover w-full h-full" />
        </div>
        <h3 class="font-bold text-white uppercase tracking-wider text-sm">Guantes de Cuero Personalizados</h3>
        <p class="text-xs text-zinc-400 mt-2 mb-4">Cuero legítimo con grabado láser del Capítulo Río Uruguay.</p>
        <div class="mt-auto flex justify-between items-center">
          <span class="text-[#d4af37] font-bold">$1.850</span>
          <a href="/#contacto" class="text-[10px] bg-[#d4af37] text-black px-3 py-1 rounded font-bold uppercase hover:bg-white transition-colors">Consultar</a>
        </div>
      </div>

      <div class="flex flex-col p-4 border border-[#d4af37]/20 rounded-lg bg-zinc-900/50 hover:border-[#d4af37] transition-all">
        <div class="aspect-square bg-zinc-800 rounded mb-4 overflow-hidden flex items-center justify-center">
          <Image src={imgGorros} alt="Gorros de nuestro capítulo" class="object-cover w-full h-full" />
        </div>
        <h3 class="font-bold text-white uppercase tracking-wider text-sm">Gorros de nuestro Capítulo</h3>
        <p class="text-xs text-zinc-400 mt-2 mb-4">Ajustables con bordado dorado de alta calidad.</p>
        <div class="mt-auto flex justify-between items-center">
          <span class="text-[#d4af37] font-bold">$850</span>
          <a href="/#contacto" class="text-[10px] bg-[#d4af37] text-black px-3 py-1 rounded font-bold uppercase hover:bg-white transition-colors">Consultar</a>
        </div>
      </div>

      <div class="flex flex-col p-4 border border-[#d4af37]/20 rounded-lg bg-zinc-900/50 hover:border-[#d4af37] transition-all">
        <div class="aspect-square bg-zinc-800 rounded mb-4 overflow-hidden flex items-center justify-center">
          <Image src={imgVelas} alt="Velas decorativas línea simbólica" class="object-cover w-full h-full" />
        </div>
        <h3 class="font-bold text-white uppercase tracking-wider text-sm">Velas Línea Simbólica WS</h3>
        <p class="text-xs text-zinc-400 mt-2 mb-4">Velas artesanales con simbología de los Widows Sons.</p>
        <div class="mt-auto flex justify-between items-center">
          <span class="text-[#d4af37] font-bold">$450</span>
          <a href="/#contacto" class="text-[10px] bg-[#d4af37] text-black px-3 py-1 rounded font-bold uppercase hover:bg-white transition-colors">Consultar</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. SECCIÓN DE SPONSORS -->
  <section id="sponsors" class="px-4 py-16 mx-auto max-w-7xl lg:py-20 bg-zinc-900/10">
    <div class="max-w-xl mb-10 md:mx-auto sm:text-center lg:max-w-2xl md:mb-12">
      <h2 class="text-[#d4af37] font-bold tracking-tight text-3xl sm:text-4xl uppercase mb-4">Programa de Socios Comerciales</h2>
      <p class="text-zinc-400">Vincula tu marca con la solidaridad. Tu apoyo financia nuestras intervenciones en el litoral.</p>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      <div class="p-6 border border-zinc-800 rounded-lg bg-black hover:border-[#d4af37]/50 transition-all flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-white font-bold uppercase text-lg">Sponsor de Ruta</h3>
          <Icon name="tabler:bike" class="w-6 h-6 text-[#d4af37]" />
        </div>
        <ul class="text-sm text-zinc-400 space-y-2 mb-6 flex-grow">
          <li>• Logo en la web oficial.</li>
          <li>• Mención en agradecimientos.</li>
          <li>• Certificado de Socio Comercial.</li>
        </ul>
        <a href="/#contacto" class="w-full text-center py-2 border border-[#d4af37] text-[#d4af37] font-bold uppercase text-xs rounded">Solicitar Información</a>
      </div>

      <div class="p-6 border-2 border-[#d4af37] rounded-lg bg-zinc-900 flex flex-col transform lg:scale-105 shadow-xl">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-white font-bold uppercase text-lg">Sponsor Litoral</h3>
          <Icon name="tabler:crown" class="w-6 h-6 text-[#d4af37]" />
        </div>
        <p class="text-[10px] text-[#d4af37] font-bold uppercase mb-2">Más Popular</p>
        <ul class="text-sm text-zinc-300 space-y-2 mb-6 flex-grow">
          <li>• Logo en fondos de Instagram.</li>
          <li>• Espacio publicitario en Eventos.</li>
          <li>• Logo en parches especiales.</li>
        </ul>
        <a href="/#contacto" class="w-full text-center py-2 bg-[#d4af37] text-black font-bold uppercase text-xs rounded">Unirse al Programa</a>
      </div>

      <div class="p-6 border border-zinc-800 rounded-lg bg-black hover:border-[#d4af37]/50 transition-all flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-white font-bold uppercase text-lg">Aliado Estratégico</h3>
          <Icon name="tabler:hand-stop" class="w-6 h-6 text-[#d4af37]" />
        </div>
        <ul class="text-sm text-zinc-400 space-y-2 mb-6 flex-grow">
          <li>• Alianzas por insumos o servicios.</li>
          <li>• Presencia en puntos de recolección.</li>
          <li>• Co-branding en acciones sociales.</li>
        </ul>
        <a href="/#contacto" class="w-full text-center py-2 border border-[#d4af37] text-[#d4af37] font-bold uppercase text-xs rounded">Proponer Alianza</a>
      </div>
    </div>
  </section>

  <!-- 4. DONACIÓN CIVIL -->
  <section id="donaciones" class="px-4 py-16 mx-auto max-w-7xl lg:py-20 bg-zinc-900/30 rounded-lg">
    <div class="max-w-xl mb-10 md:mx-auto sm:text-center lg:max-w-2xl md:mb-12">
      <h2 class="text-[#d4af37] font-bold tracking-tight text-3xl sm:text-4xl uppercase mb-4">Donación Civil</h2>
      <p class="text-zinc-400">Tu tiempo y lo que ya no usas pueden cambiar una realidad.</p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      <div class="p-5 border border-[#d4af37]/20 rounded shadow-sm bg-black">
        <h3 class="mb-2 font-bold text-white uppercase">Donaciones Materiales</h3>
        <p class="text-sm text-zinc-300">Ropa en buen estado, calzado o artículos de necesidad para nuestras rodadas solidarias.</p>
      </div>
      <div class="p-5 border border-[#d4af37]/20 rounded shadow-sm bg-black">
        <h3 class="mb-2 font-bold text-white uppercase">Aportes Económicos</h3>
        <p class="text-sm text-zinc-300">Transferencias directas para compra de insumos médicos o materiales de construcción.</p>
      </div>
    </div>
  </section>

  <!-- 5. CTA FINAL -->
  <CallToAction
    actions={[{ variant: 'primary', text: 'Contactar para Donar', href: '/#contacto' }]}
    title="¿Tienes algo para entregar?"
    subtitle="Contáctanos y coordinamos la logística para retirar tu donación o facilitarte los medios de transferencia."
  />
</Layout>
