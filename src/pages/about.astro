---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Quiénes Somos — Widows Sons Río Cuareim',
};
---

<Layout metadata={metadata}>
  <!-- 1. IDENTIDAD INTEGRADA DE LA FRONTERA NORTE -->
  <Hero
    tagline="Nuestra Identidad"
    image={{
      src: '~/assets/images/img1.png',
      alt: 'Widows Sons Río Cuareim',
    }}
  >
    <Fragment slot="title">
      Widows Sons <br />
      <span class="text-[#d4af37] dark:text-[#d4af37]">Chapter Río Cuareim</span>
    </Fragment>

    <Fragment slot="subtitle">
      Somos una hermandad de Masones activos que, bajo los principios universales de la Masonería y con el respaldo del Gran Chapter de Uruguay, encuentran en el motociclismo un vehículo de unión, servicio y presencia en el extremo norte del país. Nuestro nombre evoca las aguas del Río Cuareim, símbolo de mística, hermandad e integración en nuestras fronteras.
    </Fragment>
  </Hero>

  <!-- 2. NUESTRA MISIÓN -->
  <Features3
    title="Nuestra Misión"
    subtitle="La fraternidad y la asistencia social no conocen límites geográficos."
    columns={4}
    items={[
      { title: 'Filantropía', description: 'Acción en el Norte', icon: 'tabler:heart-handshake' },
      { title: 'Integración', description: 'Nuestra Identidad', icon: 'tabler:world-latitude' },
      { title: 'Social', description: 'Impacto Comunitario', icon: 'tabler:users' },
      { title: 'Fraternidad', description: 'Nuestro Motor', icon: 'tabler:engine' },
    ]}
    classes={{
      icon: 'text-[#d4af37]',
    }}
  />

  <!-- 3. PRESENCIA TERRITORIAL CENTRALIZADA EN EL NORTE -->
  <Features3
    title="Presencia en la Frontera Norte"
    subtitle="Consolidando un espacio de integración fraternal y apoyo comunitario en los límites geográficos de nuestro territorio."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Artigas (Sede)',
        description: 'Base principal de nuestras operaciones, asambleas y gestión institucional del Chapter.',
        icon: 'tabler:map-pin-filled',
      },
      {
        title: 'Bella Unión',
        description: 'Extensión de nuestro compromiso solidario y presencia activa en la triple frontera.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Rutas de Integración',
        description: 'Establecemos puentes y estrechamos lazos de fraternidad con los hermanos de la región.',
        icon: 'tabler:world-latitude',
      },
    ]}
    classes={{
      icon: 'text-[#d4af37]',
    }}
  />

  <!-- 4. NUESTROS VALORES MASONICOS -->
  <Steps2
    title="Nuestros Valores"
    subtitle="Los pilares masónicos que guían cada kilómetro de nuestra marcha norteña."
    items={[
      {
        title: 'Fraternidad sin Límites',
        description: 'Unión genuina entre hermanos que trasciende barreras geográficas y culturales.',
      },
      {
        title: 'Solidaridad Territorial',
        description: 'Compromiso social sostenido para atender las necesidades particulares de la comunidad artiguense.',
      },
      {
        title: 'Honor y Rectitud',
        description: 'Coherencia absoluta entre nuestros juramentos en el taller y nuestra conducta en las rutas públicas.',
      },
    ]}
  />

  <!-- 5. NUESTRO COMPROMISO FRONTERIZO -->
  <Steps2
    title="Nuestro Compromiso"
    subtitle="No somos solo un grupo de motociclistas. Somos una hermandad que actúa, construye y deja huella en el norte uruguayo."
    isReversed={true}
    callToAction={{
      text: 'Ver nuestras actividades',
      href: '/blog',
    }}
    items={[
      {
        title: 'Acción Concreta',
        description: 'Transformamos los principios masónicos en hechos visibles de ayuda civil.',
        icon: 'tabler:tool',
      },
      {
        title: 'Vínculo Social',
        description: 'Generamos un impacto positivo colaborando estrechamente con las comunidades del Río Cuareim.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Conducta Ejemplar',
        description: 'Máximo ejemplo de civismo, fraternidad y respeto mutuo en la vía pública.',
        icon: 'tabler:certificate',
      },
    ]}
    classes={{
      icon: 'text-[#d4af37]',
    }}
  />

  <!-- 6. ÁMBITO DE ACCIÓN -->
  <Features2
    title="Dónde nos encontramos"
    tagline="Territorio"
    columns={3}
    items={[
      {
        title: 'Rutas del Norte',
        description: 'Nuestra zona principal de rodadas, recorridos oficiales y patrullas.',
      },
      {
        title: 'Sedes Masónicas',
        description: 'Puntos de encuentro institucional bajo la regularidad de la orden.',
      },
      {
        title: 'Paradas Solidarias',
        description: 'Presencia itinerante y campañas de asistencia en localidades vulnerables.',
      },
    ]}
  />

  <!-- 7. CONTACTO ADAPTADO -->
  <Features2
    title="Contacto Institucional"
    tagline="Comunícate"
    columns={2}
    items={[
      {
        title: 'Mensaje Directo',
        description: 'Coordinación de apoyo, donaciones locales y campañas solidarias en Artigas.',
        icon: 'tabler:messages',
      },
      {
        title: 'Membresía',
        description: 'Información y recepción de solicitudes para Masones de la región interesados.',
        icon: 'tabler:id-badge-2',
      },
    ]}
    classes={{
      icon: 'text-[#d4af37]',
    }}
  />
</Layout>
